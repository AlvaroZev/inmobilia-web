{
  "id": "closet-001",
  "name": "Closet empotrado 2.40m",
  "description": "Closet de melamina con dos cuerpos y cajonera inferior",
  "root": {
    "id": "root",
    "label": "Cuerpo principal",
    "constraints": {
      "width": { "mode": "fill" },
      "height": { "mode": "fill" },
      "depth": { "mode": "fixed", "value": 600 }
    },
    "split": {
      "axis": "x",
      "ratios": [0.5, 0.5]
    },
    "children": [
      {
        "id": "left-body",
        "label": "Cuerpo izquierdo",
        "constraints": {
          "width": { "mode": "ratio", "value": 0.5 },
          "height": { "mode": "fill" },
          "depth": { "mode": "fill" }
        },
        "children": [],
        "features": [
          {
            "id": "shelves-left",
            "type": "shelf_set",
            "params": { "count": 4, "spacing": "equal" }
          },
          {
            "id": "rod-left",
            "type": "hanger_rod",
            "params": { "heightFromTop": 1800 }
          }
        ],
        "fronts": [
          {
            "id": "door-left",
            "type": "door",
            "params": { "hinge": "left", "materialId": "melamine-white" }
          }
        ]
      },
      {
        "id": "right-body",
        "label": "Cuerpo derecho",
        "constraints": {
          "width": { "mode": "ratio", "value": 0.5 },
          "height": { "mode": "fill" },
          "depth": { "mode": "fill" }
        },
        "split": {
          "axis": "y",
          "ratios": [0.7, 0.3]
        },
        "children": [
          {
            "id": "right-upper",
            "label": "Repisas superiores",
            "constraints": {
              "width": { "mode": "fill" },
              "height": { "mode": "ratio", "value": 0.7 },
              "depth": { "mode": "fill" }
            },
            "children": [],
            "features": [
              {
                "id": "shelves-right",
                "type": "shelf_set",
                "params": { "count": 3, "spacing": "equal" }
              }
            ],
            "fronts": [
              {
                "id": "door-right",
                "type": "door",
                "params": { "hinge": "right", "materialId": "melamine-white" }
              }
            ]
          },
          {
            "id": "right-drawers",
            "label": "Cajonera",
            "constraints": {
              "width": { "mode": "fill" },
              "height": { "mode": "ratio", "value": 0.3 },
              "depth": { "mode": "fill" }
            },
            "children": [],
            "features": [
              {
                "id": "drawers",
                "type": "drawer_stack",
                "params": { "count": 3, "runner": "soft-close" }
              }
            ],
            "fronts": [
              {
                "id": "drawer-fronts",
                "type": "drawer_front",
                "params": { "materialId": "melamine-white" }
              }
            ]
          }
        ],
        "features": [],
        "fronts": []
      }
    ],
    "features": [],
    "fronts": [],
    "adaptation": {
      "followFloor": true,
      "followCeiling": true,
      "compensateSkirting": true
    },
    "manufacturing": {
      "materialId": "melamine-white-18",
      "edgeBanding": "pvc-white-1mm",
      "backPanel": true
    }
  }
}
