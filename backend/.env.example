# Copy to backend/.env and fill in your values.
# The server loads this file automatically when started from backend/.

# HTTP
PORT=8080
GIN_MODE=debug

# CORS (use a single origin in production, e.g. https://app.example.com)
CORS_ALLOWED_ORIGIN=*

# Reverse proxy trust list (comma-separated IPs). Use "none" to disable.
# TRUSTED_PROXIES=127.0.0.1,::1

# AI provider: mock | openai
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
